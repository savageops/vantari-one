# Default local OpenAI-compatible provider example
OPENAI_BASE_URL=http://127.0.0.1:1234
OPENAI_API_KEY=sk-your-local-provider-key
OPENAI_MODEL=gemma-4-26b-a4b-it-apex
HARNESS_MAX_STEPS=28
HARNESS_WORKSPACE=.

# Example remote provider shape
# OPENAI_BASE_URL=https://api.example.com/v1
# OPENAI_API_KEY=replace-with-remote-provider-key
# OPENAI_MODEL=provider-model-name

